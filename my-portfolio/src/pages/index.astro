---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const featuredProjects = await getCollection('projects', ({ data }) => {
  return data.isFeatured === true;
});

const recentLogs = await getCollection('logs');
recentLogs.sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());
const displayLogs = recentLogs.slice(0, 4);

const skillCategories = [
  { title: "Languages", skills: ["C++", "C#", "JavaScript", "TypeScript", "HTML/CSS"] },
  { title: "Engines & Frameworks", skills: ["Unity", "Unreal Engine", "Custom Engines", "Astro", "React"] },
  { title: "Tools & Software", skills: ["Git / GitHub", "Visual Studio", "RenderDoc", "Perforce"] }
];
---

<BaseLayout title="Gideon Francis | Systems & Gameplay Programmer">
  
  <section class="flex flex-col-reverse md:flex-row md:items-center justify-between gap-12 md:my-16">
    <div class="space-y-6 flex-1">
      <div class="space-y-2">
        <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight font-sans text-zinc-900 dark:text-zinc-50">
          Gideon Francis
        </h1>
        <h2 class="text-lg md:text-xl text-zinc-600 dark:text-zinc-400 font-medium font-sans">
          Gameplay and Software Developer
        </h2>
      </div>

    <p class="text-sm md:text-base leading-relaxed text-zinc-600 dark:text-zinc-400 max-w-2xl font-sans">
        Hey! I'm Gideon! Welcome to my website. You can visit my <a href="/projects" class="text-indigo-600 dark:text-indigo-400 hover:underline">projects</a> to find out more about what I've done.
		<br>
		<br>
		I love working together with people to create something, whether it is a game or not. If it helps people as a tool, or provide entertainment, it provides me with a sense of 
		fulfilment knowing that I was part of the team that made that.
    </p>
      
      <div class="pt-4 flex gap-4 text-xs md:text-sm">
        <a href="/projects" class="px-6 py-3 bg-zinc-900 dark:bg-zinc-800 text-zinc-100 dark:text-zinc-200 border border-zinc-800 dark:border-zinc-700 rounded-lg hover:bg-indigo-600 hover:border-indigo-500 hover:text-white transition font-sans font-semibold">
          My Projects
        </a>
        <a href="/AboutMe" class="px-6 py-3 bg-zinc-900 dark:bg-zinc-800 text-zinc-100 dark:text-zinc-200 border border-zinc-800 dark:border-zinc-700 rounded-lg hover:bg-indigo-600 hover:border-indigo-500 hover:text-white transition font-sans font-semibold">
          About me
        </a>
        <a href="https://github.com/gideonnf" target="_blank" class="px-6 py-3 text-zinc-600 dark:text-zinc-400 border border-zinc-200 dark:border-zinc-800 rounded-lg hover:text-zinc-900 dark:hover:text-zinc-200 hover:border-zinc-300 dark:hover:border-zinc-700 transition">
          My Github
        </a>
      </div>
    </div>

    <div class="w-72 h-102 md:w-96 md:h-120 shrink-0 mx-auto md:mx-0 overflow-hidden rounded-2xl border-2 border-zinc-200 dark:border-zinc-800/50 shadow-2xl">
      <img 
        src="/GideonFusion.png" 
        alt="Gideon Francis" 
        class="w-full h-full object-cover"
      />
    </div>
  </section>
  <section class="mt-20 space-y-6">
    <div class="flex items-center justify-between border-b border-zinc-200 dark:border-zinc-800 pb-2">
      <h3 class="text-xs uppercase font-bold tracking-wider text-zinc-500 dark:text-zinc-400">Skills & Technologies</h3>
    </div>

    <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6">
      {skillCategories.map(category => (
        <div class="p-5 bg-zinc-50 dark:bg-zinc-900/40 border border-zinc-200 dark:border-zinc-800/80 rounded-lg space-y-3">
          <h4 class="font-sans font-bold text-zinc-900 dark:text-zinc-200 text-sm tracking-wide uppercase">{category.title}</h4>
          <div class="flex flex-wrap gap-2">
            {category.skills.map(skill => (
              <span class="text-xs px-2.5 py-1 font-semibold font-mono bg-zinc-100 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400 rounded border border-zinc-200 dark:border-zinc-700/50">
                {skill}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="mt-20 space-y-6">
    <div class="flex items-center justify-between border-b border-zinc-200 dark:border-zinc-800 pb-2">
      <h3 class="text-xs uppercase font-bold tracking-wider text-zinc-500 dark:text-zinc-400">Showcase Projects</h3>
      <a href="/projects" class="text-xs text-indigo-600 dark:text-indigo-400 hover:underline">View all projects</a>
    </div>

    <div class="grid md:grid-cols-2 gap-4">
      {featuredProjects.map(project => (
        <a href={`/projects/${project.id}`} class="block p-5 bg-zinc-50 dark:bg-zinc-900/40 border border-zinc-200 dark:border-zinc-800/80 rounded-lg space-y-4 hover:border-indigo-500/50 dark:hover:border-indigo-500/50 transition group">
          <div class="space-y-1">
            <h4 class="font-sans font-bold text-zinc-900 dark:text-zinc-200 text-base group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition">{project.data.title}</h4>
            <p class="text-xs text-zinc-600 dark:text-zinc-400 font-sans leading-relaxed line-clamp-3">{project.data.description}</p>
          </div>
          <div class="flex flex-wrap gap-1.5">
            {project.data.tags.map(tag => (
              <span class="text-[10px] px-2 py-0.5 font-semibold font-mono bg-zinc-100 dark:bg-zinc-800 text-zinc-500 dark:text-zinc-400 rounded border border-zinc-200 dark:border-zinc-700/50">{tag}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </section>

    <section class="mt-20 space-y-6">
    <div class="flex items-center justify-between border-b border-zinc-200 dark:border-zinc-800 pb-2">
      <h3 class="text-xs uppercase font-bold tracking-wider text-zinc-500 dark:text-zinc-400">Most recent logs</h3>
      <a href="/logs" class="text-xs text-indigo-600 dark:text-indigo-400 hover:underline">View all logs</a>
    </div>

    <div class="grid md:grid-cols-2 gap-4">
      {displayLogs.map(log => (
        <a href={`/logs/${log.id}`} class="p-4 bg-zinc-50 dark:bg-zinc-900/40 border border-zinc-200 dark:border-zinc-800/80 rounded-lg space-y-2 hover:border-indigo-500/50 transition group">
          <time class="text-[10px] font-mono text-zinc-500 uppercase">{log.data.publishDate}</time>
          <h4 class="font-sans font-bold text-zinc-900 dark:text-zinc-200 text-sm group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition">{log.data.title}</h4>
          <p class="text-xs text-zinc-600 dark:text-zinc-400 font-sans line-clamp-2">{log.data.description}</p>
        </a>
      ))}
    </div>
  </section>


</BaseLayout>