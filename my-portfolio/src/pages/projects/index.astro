---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
// Sort by title or date if available
allProjects.sort((a, b) => a.data.title.localeCompare(b.data.title));
---

<BaseLayout title="Projects | Gideon Francis">
  <section class="mt-12 space-y-8">
    <div class="space-y-2">
      <h1 class="text-3xl font-bold tracking-tight text-zinc-900 dark:text-zinc-50">All Projects</h1>
      <p class="text-zinc-600 dark:text-zinc-400">A collection of my work in gameplay and software development.</p>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      {allProjects.map(project => (
        <a href={`/projects/${project.id}`} class="block group">
          <div class="p-6 bg-zinc-50 dark:bg-zinc-900/40 border border-zinc-200 dark:border-zinc-800/80 rounded-xl space-y-4 group-hover:border-indigo-500/50 dark:group-hover:border-indigo-500/50 transition">
            <div class="space-y-2">
              <h2 class="font-sans font-bold text-zinc-900 dark:text-zinc-200 text-xl group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition">{project.data.title}</h2>
              <p class="text-sm text-zinc-600 dark:text-zinc-400 font-sans leading-relaxed line-clamp-2">{project.data.description}</p>
            </div>
            <div class="flex flex-wrap gap-2">
              {project.data.tags.map(tag => (
                <span class="text-[11px] px-2.5 py-1 font-semibold font-mono bg-zinc-100 dark:bg-zinc-800 text-zinc-500 dark:text-zinc-400 rounded border border-zinc-200 dark:border-zinc-700/50">{tag}</span>
              ))}
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
