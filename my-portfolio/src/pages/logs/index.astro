---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allLogs = await getCollection('logs');
allLogs.sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());
---

<BaseLayout title="Logs | Gideon Francis">
  <section class="mt-12 space-y-8">
    <div class="space-y-2">
      <h1 class="text-3xl font-bold tracking-tight text-zinc-900 dark:text-zinc-50">Devlogs & Thoughts</h1>
      <p class="text-zinc-600 dark:text-zinc-400">Regular updates on my projects and technical explorations.</p>
    </div>

    <div class="space-y-12">
      {allLogs.map(log => (
        <article class="space-y-4">
          <div class="space-y-2">
            <time class="text-xs font-mono text-zinc-500 uppercase">{log.data.publishDate}</time>
            <h2 class="text-2xl font-bold text-zinc-900 dark:text-zinc-100">
              <a href={`/logs/${log.id}`} class="hover:text-indigo-600 dark:hover:text-indigo-400 transition">
                {log.data.title}
              </a>
            </h2>
            <p class="text-zinc-600 dark:text-zinc-400 leading-relaxed max-w-2xl">{log.data.description}</p>
          </div>
          <a href={`/logs/${log.id}`} class="text-sm font-semibold text-indigo-600 dark:text-indigo-400 hover:underline">
            Read more &rarr;
          </a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
