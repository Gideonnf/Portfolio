---
// src/layouts/BaseLayout.astro
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <!-- Add your favorite developer font if you want, like JetBrains Mono or Fira Code -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap" rel="stylesheet">
  </head>
  <body class="bg-zinc-950 text-zinc-100 min-h-screen flex flex-col font-mono selection:bg-indigo-500/30 selection:text-indigo-200">
    
    <!-- Unified Header Navigation -->
    <header class="border-b border-zinc-800/60 sticky top-0 bg-zinc-950/80 backdrop-blur-md z-50">
      <div class="max-w-4xl mx-auto px-6 h-16 flex items-center justify-between">
        <a href="/" class="text-sm font-bold tracking-tight text-zinc-400 hover:text-white transition">
          gideon_francis<span class="text-indigo-400">.init()</span>
        </a>
        <nav class="flex space-x-6 text-xs tracking-wider uppercase font-sans font-semibold text-zinc-400">
          <a href="/" class="hover:text-indigo-400 transition">Home</a>
          <a href="/projects" class="hover:text-indigo-400 transition">Projects</a>
          <a href="/blog" class="hover:text-indigo-400 transition">Devlog</a>
        </nav>
      </div>
    </header>

    <!-- Page Content will inject right here dynamically -->
    <main class="flex-1 max-w-4xl w-full mx-auto">
      <slot />
    </main>

    <footer class="border-t border-zinc-900 py-6 text-center text-xs text-zinc-600">
      &copy; {new Date().getFullYear()} Gideon Francis. Built with Astro.js and Tailwind.
    </footer>
  </body>
</html>